rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — owner can write, any auth user can read
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Watched films — owner writes, any auth reads (for friends)
      match /watchedFilms/{filmId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Friends subcollection — owner writes, any auth reads
      match /friends/{friendUid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Notifications — owner can read/delete, admin can write
      match /notifications/{notifId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null && request.auth.token.email == 'pyfingg@gmail.com';
      }
    }

    // Public profiles — owner writes, any auth reads (for search)
    match /publicProfiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Friend requests
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      allow read: if request.auth != null && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow update, delete: if request.auth != null && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // Chats — any auth user can read/write (validated in app)
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Admin settings — any auth user can READ (for ban check), only admin writes
    match /admin/settings {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == 'pyfingg@gmail.com';
    }

    // Admin messages log — only admin
    match /admin/messages/items/{messageId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'pyfingg@gmail.com';
    }
  }
}
